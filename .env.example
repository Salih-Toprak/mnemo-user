# ── Identity ──────────────────────────────────────────
USER_ID=user-001
DISPLAY_NAME=My Assistant
CONTAINER_TYPE=user

# ── Data ──────────────────────────────────────────────
DATA_DIR=/app/data

# ── Vector DB ─────────────────────────────────────────
VECTORDB_BACKEND=qdrant
VECTORDB_URL=http://qdrant:6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=company_knowledge

# Pinecone (set VECTORDB_BACKEND=pinecone)
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=

# ── Embeddings ────────────────────────────────────────
EMBEDDING_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768

# OpenAI (set EMBEDDING_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small
# EMBEDDING_VECTOR_SIZE=1536

# ── LLM ───────────────────────────────────────────────
LLM_BACKEND=ollama
OLLAMA_LLM_URL=http://ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:3b
LLM_TIMEOUT=120.0
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# OpenAI LLM (set LLM_BACKEND=openai)
# OPENAI_LLM_API_KEY=sk-...
# OPENAI_LLM_MODEL=gpt-4o-mini

# ── rag-wiki ──────────────────────────────────────────
RAG_WIKI_FETCH_THRESHOLD=3
RAG_WIKI_DECAY_INTERVAL_HOURS=24
RAG_WIKI_TOP_K=5

# ── Auth ──────────────────────────────────────────────
MASTER_API_KEY=
USER_API_KEY=

# ── MCP ───────────────────────────────────────────────
MCP_ENABLED=true
MCP_SERVER_NAME=

# ── App ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
